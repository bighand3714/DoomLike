# ==============================================================================
# Damageable — 可受伤接口
# ==============================================================================
# 挂到任何"能被子弹打中"的节点下面，它就能接收伤害。
# 设计思路：
#   这是一个独立的 Node（不负责 3D 模型/碰撞），专门管"血量"这件事。
#   之所以不和 3D 节点绑在一起，是因为可以被很多不同类型的东西复用：
#   - 玩家（CharacterBody3D）
#   - 敌人（CharacterBody3D）
#   - 靶子（CSGBox3D / StaticBody3D）
#   - 爆炸桶（RigidBody3D）
#   - 未来的 Boss（任何自定义节点）
#
# 使用方式：
#   在你的节点下添加一个 Damageable 子节点，设置 max_health，
#   然后连接 died 和 damaged 信号做反应即可（闪红、播放动画、掉落物品……）。
# ==============================================================================

# extends Node 是最基础的节点类型——只需要信号收发和变量存储，不需要 3D 功能
class_name Damageable extends Node


# ==============================================================================
# 信号（Signal）
# ==============================================================================
# 信号是 Godot 的"广播"机制——当某件事发生时，通知所有"订阅者"。
# 其他节点用 .connect() 订阅信号，这样就不需要每帧检查"它死了没有"。

## 生命值归零时发射（只发射一次）
signal died()

## 每次受到伤害时发射
## @param amount 伤害数值
## @param damage_type 伤害类型（HITSCAN / PROJECTILE / EXPLOSION / MELEE）
signal damaged(amount: float, damage_type: WeaponData.DamageType)


# ==============================================================================
# 属性
# ==============================================================================

## 最大生命值——在 Godot 编辑器中可以调
@export var max_health: float = 100.0

## 当前生命值——游戏开始时自动等于 max_health，受伤后减少
## 不导出（非 @export），因为这是运行时状态，不需要保存在资源文件中
var health: float


# ==============================================================================
# _ready() — 初始化
# ==============================================================================
func _ready() -> void:
	health = max_health


# ==============================================================================
# take_damage() — 受到伤害
# ==============================================================================
# 这是 Damageable 的核心方法。所有武器/投射物的"打中目标"逻辑，
# 最终都会调用这个方法。
#
# 参数：
#   amount —— 伤害数值（比如手枪一发 15 点）
#   damage_type —— 伤害类型，默认用 HITSCAN（瞬时命中类武器）
func take_damage(amount: float, damage_type: WeaponData.DamageType = WeaponData.DamageType.HITSCAN) -> void:
	# 已经死了就不重复扣血（防止尸体被鞭尸时不停发射死亡信号）
	if is_dead():
		return

	health -= amount

	# 通知所有订阅者"我受伤了"——比如靶子听到后会闪红
	damaged.emit(amount, damage_type)

	# 血扣到 0 以下时死亡
	if health <= 0.0:
		health = 0.0
		died.emit()


# ==============================================================================
# is_dead() — 检查是否已死亡
# ==============================================================================
# 其他脚本用这个检查状态，比直接读 health <= 0 更语义清晰。
func is_dead() -> bool:
	return health <= 0.0
