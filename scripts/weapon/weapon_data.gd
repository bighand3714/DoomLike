# ==============================================================================
# WeaponData — 武器数据蓝图 + 伤害/射击类型枚举
# ==============================================================================
# 这个文件只定义"数据长什么样"，不包含任何 3D 节点或游戏逻辑。
# 把数据和工作逻辑分开的好处：
#   1. 可以在 Godot 编辑器里直接创建/修改武器配置（.tres 文件）
#   2. 同一个武器数据可以被多个敌人/玩家共用
#   3. 存档时只需要保存数据，不需要保存整个节点树
#
# 使用方式：
#   在 Godot 编辑器的文件面板右键 → 新建资源 → WeaponData
#   就能得到一个武器配置文件，在右侧面板调参数即可。
#
# 注意：class_name 必须是文件里第一个语句（注释除外）。
#       因此 DamageType 枚举放在 WeaponData 类内部，外部用 WeaponData.DamageType 引用。
# ==============================================================================

class_name WeaponData extends Resource


# ==============================================================================
# DamageType — 伤害类型枚举（属于 WeaponData 类）
# ==============================================================================
# enum 是一组有名字的选项，比直接写数字（0, 1, 2, 3）更可读。
# 例如 if damage_type == WeaponData.DamageType.HITSCAN 比 if type == 0 好理解。
#
# 因为放在了 WeaponData 类内部，外部引用时需要写完整路径：
#   WeaponData.DamageType.HITSCAN
# 同类内部可以直接用 DamageType.HITSCAN。
enum DamageType {
	HITSCAN,    # 瞬时命中——射线检测，开枪即命中，没有飞行时间（手枪、步枪、霰弹）
	PROJECTILE, # 飞行投射物——子弹/火球在空中飞，有飞行时间（火箭弹、Imp火球）
	EXPLOSION,  # 范围爆炸——对爆炸半径内的所有东西造成伤害（火箭弹爆炸、桶爆炸）
	MELEE,      # 近战攻击——贴脸时才能造成伤害（拳头、电锯、恶魔啃咬）
}


# ==============================================================================
# FireMode — 射击模式枚举
# ==============================================================================
# 不同的枪有不同的扳机逻辑：
#   SEMI（半自动）：按一下打一发，按住不会连发（手枪）
#   AUTO（全自动）：按住鼠标就一直打（机关枪）
#   PUMP（泵动式）：打一发后需要短暂动画（泵动），动画结束才能打下一发（霰弹枪）
enum FireMode {
	SEMI,   # 半自动 = Semi-automatic，每次扣扳机打一发
	AUTO,   # 全自动 = Fully automatic，按住连发
	PUMP,   # 泵动式 = Pump-action，打一发 → 拉泵 → 才能再打
}


# ==============================================================================
# 基础信息
# ==============================================================================

## 武器显示名称，比如 "手枪"、"霰弹枪"、"突击步枪"
@export var weapon_name: String = "未命名武器"

## 武器在武器栏里占第几个格子（0 = 第1格，1 = 第2格，以此类推）
@export var slot_index: int = 0


# ==============================================================================
# 伤害参数——决定这把枪"打人有多疼"
# ==============================================================================

## 每颗弹丸的基础伤害值
##   - 手枪：15 点，打普通敌人 3-4 枪打死
##   - 霰弹枪：10 点 × 7 颗弹丸 = 全中时 70 点，贴脸秒杀
@export var damage: float = 10.0

## 最大射程（米），超过这个距离射线不会命中任何东西
##   - 手枪：50m
##   - 霰弹枪：25m（弹丸散射，远了打不中）
##   - 步枪：80m
@export var max_range: float = 50.0

## 伤害类型，决定"怎么造成伤害"——射线？飞行弹？还是爆炸？
@export var damage_type: DamageType = DamageType.HITSCAN


# ==============================================================================
# 射速与弹药——决定这把枪"能打多快"和"能打多少发"
# ==============================================================================

## 射速：每秒能打多少发子弹
##   - 2.5 = 每 0.4 秒打一发（手枪）
##   - 10.0 = 每秒 10 发（冲锋枪）
##   - 炮/霰弹枪因为 fire_mode = PUMP，实际射速由泵动动画控制
@export var fire_rate: float = 2.0

## 射击模式：半自动 / 全自动 / 泵动式
@export var fire_mode: FireMode = FireMode.SEMI

## 弹匣容量——装满一个弹匣需要多少发子弹
##   - 手枪：8 发
##   - 霰弹枪：2 发
##   - 步枪：30 发
@export var mag_size: int = 8

## 备弹数量——弹匣打完后，总共还有多少发子弹可以装填
##   例如手枪 mag_size=8, reserve_ammo=50 → 可以打 8+(50-8)=50 发（换弹 6 次）
@export var reserve_ammo: int = 50

## 换弹时间（秒）——从按下 R 到弹匣补满需要多久
##   - 手枪：1.2 秒
##   - 霰弹枪：2.5 秒（一发一发往里塞）
@export var reload_time: float = 1.5


# ==============================================================================
# 精度参数——决定这把枪"打得有多准"
# ==============================================================================

## 散布角度（度数）：子弹实际飞行方向与准星方向的最大偏差
##   - 0.0 = 完美精准，子弹打在准星正中央（狙击枪）
##   - 2.0 = 轻微散布（手枪）
##   - 10.0 = 大范围散射（霰弹枪）
##
## 原理：以准星方向为轴，扩散角为半径画一个圆锥，
##       每颗弹丸在圆锥内随机选一个方向飞出去。
##       角度越大 → 圆锥越胖 → 子弹越散。
@export var spread_angle: float = 0.0

## 弹丸数量：每次射击射出多少颗弹丸
##   - 1 = 普通枪（手枪、步枪），一次只射一发
##   - 7 = 霰弹枪，一次喷出 7 颗弹丸
##   - 弹丸多了配合 spread_angle 才能形成散射效果
@export var pellet_count: int = 1

## 每颗弹丸命中时造成的眩晕值
##   - 手枪：8.0，单发中等眩晕
##   - 霰弹枪：5.0 × 7 = 全中 35.0，贴脸高眩晕
##   - 铁鞭：40.0，独立控制，不走 WeaponData
@export var stun_damage: float = 0.0

## 移动时的散布惩罚倍数
##   - 1.0 = 移动不影响精度
##   - 1.5 = 移动时散布角度 × 1.5（跑动中更难瞄准）
##   - 实际计算：最终散布 = spread_angle × move_spread_mult
@export var move_spread_mult: float = 1.5

## 每颗弹丸命中时造成的击退力度
@export var knockback_force: float = 0.0


# ==============================================================================
# 特殊行为标记
# ==============================================================================

## 无限弹药——true 时射击不扣弹匣、不触发换弹（手枪保底、拳头）
@export var infinite_ammo: bool = false

## 近战武器标记——true 时使用近战距离判定而非射线检测
@export var is_melee: bool = false

## 近战攻击距离（米），仅在 is_melee=true 时生效
@export var melee_range: float = 2.0

## 是否需要手动上膛（如泵动式霰弹枪）
##   - true：射击后自动进入"上膛"阶段，期间不能开枪
##   - false：射击后只需等 fire_rate 冷却即可再开枪
##   这个值由 fire_mode 自动决定（PUMP = true, 其余 = false），
##   放在这里是为了方便在代码中检查。
var needs_pump: bool:
	get:
		return fire_mode == FireMode.PUMP

## 弹匣当前装弹量（运行时数据，不由编辑器保存）
## 游戏开始时初始化为 mag_size，之后每打一发减 1。
## 注意：这里没加 @export，因为这是"运行时状态"不是"配置参数"。
var current_ammo: int = 0
