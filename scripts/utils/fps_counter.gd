# ==============================================================================
# FPSCounter — 显示实时帧率
# ==============================================================================
# 挂在一个 Label（文本标签）节点上。
# 每半秒更新一次显示的 FPS 数值，让玩家了解游戏运行流畅度。
#
# FPS = Frames Per Second = 每秒画面帧数
#   60 FPS = 流畅
#   30 FPS = 基本可玩
#   < 20 FPS = 明显卡顿
# ==============================================================================

# 继承 Label——这样这个脚本就有了"显示文字"的功能
extends Label


# ==============================================================================
# 内部计数变量
# ==============================================================================

## 累计经过的时间（秒），每半秒重置一次
var _elapsed := 0.0

## 累计经过的帧数，每半秒重置一次
var _frames := 0


# ==============================================================================
# _process(delta) — 每渲染帧自动调用一次
# ==============================================================================
# delta = 这一帧距离上一帧的秒数。比如 60 FPS 时 delta ≈ 0.016 秒。
# 用 _process 而不是 _physics_process，因为 FPS 计数器属于"UI 显示"，
# 不需要和物理同步——用渲染帧来计算更准确。
func _process(delta: float) -> void:
	# 累加时间和帧数
	_elapsed += delta
	_frames += 1

	# 每半秒更新一次显示（等 0.5 秒采样足够数据后再算，避免数字跳得太快看不清）
	if _elapsed >= 0.5:
		# 计算 FPS = 帧数 / 时间
		# roundi() 四舍五入到整数（"i" 后缀表示返回 int 类型）
		# "%d" 是格式化占位符，表示"这里放一个整数"
		# 例如 _frames=30, _elapsed=0.5 → FPS = 30/0.5 = 60
		text = "FPS: %d" % roundi(_frames / _elapsed)

		# 重置计数器，开始下一轮采样
		_elapsed = 0.0
		_frames = 0
