# ==============================================================================
# GameModeManager — 游戏模式管理器
# ==============================================================================
# 管理游戏当前处于"游玩"还是"编辑"模式。
# 后续地图编辑器实现后，可以按 Tab 键在两模式之间切换。
#
# ⚠ 第一阶段：只定义模式和切换逻辑，实际还没有编辑器 UI。
# ==============================================================================

# extends Node 是最基础的节点类型——不需要 2D/3D 功能，只做逻辑管理
class_name GameModeManager extends Node


# ==============================================================================
# Mode 枚举——两种游戏模式
# ==============================================================================
# enum（枚举）是一组有名字的选项，比直接用数字更可读。
# 例如 if mode == Mode.PLAY 比 if mode == 0 更容易理解。
enum Mode {
	PLAY,   # 游玩模式——正常的第一人称视角，WASD 移动，可以射击
	EDIT    # 编辑模式——自由视角（类似 Godot 编辑器），可以放置/修改墙壁和实体
}


# ==============================================================================
# current_mode — 当前模式，带 setter
# ==============================================================================
# 这个变量的写法比较特殊：
#   var current_mode := Mode.PLAY :
#       set(value):
#           current_mode = value
#           mode_changed.emit(value)
#
# set 关键字定义了一个"setter"（设置器）——每次给这个变量赋值时，
# 都会自动执行 set(value): 后面的代码。
# 这样我们就能在"模式改变"的同时，自动发出信号通知其他模块。
var current_mode := Mode.PLAY :
	set(value):
		current_mode = value
		mode_changed.emit(value)


# ==============================================================================
# mode_changed 信号
# ==============================================================================
# 信号（signal）是 Godot 的"事件广播"机制。
# 当模式改变时，current_mode 的 setter 会发射（emit）这个信号。
# 其他节点可以 connect（连接）这个信号，
# 例如：UI 模块收到 PLAY 模式就显示准星，收到 EDIT 模式就显示编辑器面板。
# 这样各个模块之间不需要直接知道彼此存在——这叫"解耦"。
signal mode_changed(mode: Mode)


# ==============================================================================
# toggle() — 切换模式
# ==============================================================================
# 调用一次就从 PLAY 切到 EDIT，再调一次切回来。
# 三元表达式：condition ? a : b 的 GDScript 写法是 a if condition else b
func toggle() -> void:
	current_mode = Mode.EDIT if current_mode == Mode.PLAY else Mode.PLAY
