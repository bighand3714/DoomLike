# ==============================================================================
# LevelData — 关卡数据的"蓝图"
# ==============================================================================
# 这是一个 Resource 类。Resource 在 Godot 中是一种"数据容器"——
# 它可以被保存为 .tres 文件（纯文本）或 .res 文件（二进制），
# 也能在编辑器中像文件一样拖拽。
#
# 这个类的设计灵感来自 1993 年 DOOM 的 WAD 格式。
# DOOM 把地图分成一个个"Sector"（扇区），每个扇区是一个封闭的房间/区域，
# 扇区之间通过"Portal"（门洞/通道）连接。
# 这样做的好处：引擎只需要渲染当前扇区和可见的相邻扇区，
# 自动实现"看不见的不用画"（这叫"可见性剔除"）。
#
# ⚠ 第一阶段：只定义数据结构，还没有关卡用它。
#    后续地图编辑器会直接操作这些数据。
# ==============================================================================

# class_name 让这个类可以在其他脚本中被引用（如 var data: LevelData = ...）
# extends Resource 表示这是一个资源——可以被保存、加载、复制
class_name LevelData extends Resource


# ==============================================================================
# SurfaceDef — 地面/天花板的表面定义
# ==============================================================================
# 这个内部类表示"一块地板或天花板长什么样"。
# 目前只有纹理和高度，未启用（后续阶段会用到）。
class SurfaceDef:
	var texture: StringName = &""   # 纹理路径，如 &"res://assets/textures/floors/stone.png"
	var height: float = 0.0         # 高度（米）


# ==============================================================================
# WallDef — 一段墙壁的定义
# ==============================================================================
# DOOM 的墙壁是由"线段"（两个顶点之间的连线）定义的。
# 一段墙壁可能上下有不同纹理（因为相邻扇区可能高度不同）。
# 也可能是 Portal——连接到另一个扇区的通道。
class WallDef:
	var start := Vector2.ZERO    # 墙壁起点（2D 坐标，因为 DOOM 地图本质是 2D 平面）
	var end := Vector2.ZERO      # 墙壁终点

	# DOOM 的墙上中下三段纹理——当相邻扇区高度不同时会露出来
	var texture_upper: StringName = &""    # 上方纹理（当天花板比邻居高时可见）
	var texture_middle: StringName = &""   # 中间纹理（门洞/窗口区域）
	var texture_lower: StringName = &""    # 下方纹理（当地板比邻居低时可见）

	# portal_to = -1 表示实心墙（撞上去会挡住）
	# portal_to >= 0 表示这是一个"门洞"，通向第 N 号扇区
	var portal_to := -1


# ==============================================================================
# Sector — 扇区（关卡的核心单元）
# ==============================================================================
# 一个"扇区"就是一个封闭多边形区域，例如一个房间、一条走廊。
# 每个扇区有自己的地板高度、天花板高度、亮度。
# 墙壁（WallDef 数组）定义了这个多边形的边界。
class Sector:
	var floor_height := 0.0          # 地板距地高度（0 = 地面）
	var ceiling_height := 4.0        # 天花板高度（4 米 ≈ 标准房间高度）

	var floor_texture: StringName = &""    # 地板纹理
	var ceiling_texture: StringName = &""  # 天花板纹理

	var light_level := 160           # 亮度（0=全黑, 255=最亮，DOOM 用 0-255 整数）

	var walls: Array[WallDef] = []   # 围成这个扇区的所有墙壁


# ==============================================================================
# ThingDef — 实体放置点
# ==============================================================================
# "Thing"（东西）是 DOOM 的术语，指关卡里任何不是墙壁/地板的东西：
#   玩家出生点、怪物、武器、弹药、血包、装饰物……
class ThingDef:
	# 枚举（enum）定义了这个"东西"的类别
	enum Type {
		PLAYER_START,   # 玩家出生点——地图必须至少有一个
		ENEMY,          # 敌人/怪物
		PICKUP,         # 可拾取物品（武器、弹药、血包、护甲）
		DECORATION      # 纯装饰（柱子、火把、尸体）
	}

	var type: Type                          # 东西的类别
	var position := Vector3.ZERO            # 3D 位置
	var angle := 0.0                        # 朝向角度（度数）
	var subtype: StringName = &""           # 子类型，如 &"imp"（小恶魔）、&"shotgun"（霰弹枪）


# ==============================================================================
# 关卡数据主体
# ==============================================================================

## 扇区列表——关卡里的所有房间/区域
@export var sectors: Array = []

## 实体列表——关卡里所有可交互的东西
@export var things: Array = []

## 元数据——关卡的描述信息
# @export 让它可以在 Godot 编辑器中直接修改。
# Dictionary（字典）是一种"键→值"的容器，类似 JSON 对象。
@export var metadata := {
	name = "Untitled",   # 关卡名称
	author = "",         # 作者
	bgm = ""             # 背景音乐文件路径
}
