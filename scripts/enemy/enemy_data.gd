# ==============================================================================
# EnemyData — 敌人配置数据蓝图
# ==============================================================================
# 类似 WeaponData，把敌人的参数从代码中抽离为 Resource 文件（.tres）。
# 好处：
#   1. 不同敌人类型 = 不同的 .tres 文件，不用改代码
#   2. 可在编辑器中直接调参（生命值、速度、伤害……）
#   3. 存档时只需保存数据引用
# ==============================================================================

class_name EnemyData extends Resource


# ==============================================================================
# 基础信息
# ==============================================================================

## 敌人显示名称，如 "小恶魔"、"恶魔士兵"
@export var enemy_name: String = "未命名敌人"


# ==============================================================================
# 战斗属性
# ==============================================================================

## 最大生命值 — Imp 80, 士兵 120
@export var max_health: float = 100.0

## 每次攻击造成的伤害 — Imp 火球 15, 士兵射击 8
@export var attack_damage: float = 10.0

## 攻击类型 — HITSCAN(瞬时) / PROJECTILE(飞行弹) / MELEE(近战)
@export var damage_type: WeaponData.DamageType = WeaponData.DamageType.HITSCAN


# ==============================================================================
# AI 行为参数
# ==============================================================================

## 追击移动速度（m/s）— 比玩家慢，玩家可以风筝
@export var move_speed: float = 4.0

## 攻击触发距离（m）— 进入此距离开始攻击
@export var attack_range: float = 15.0

## 发现玩家距离（m）— 超过此距离敌人不反应
@export var sight_range: float = 30.0

## 攻击间隔（秒）— 两次攻击之间的最小冷却
@export var attack_cooldown: float = 1.0


# ==============================================================================
# 反应参数
# ==============================================================================

## 受击硬直时间（秒）— 被击中后"僵住"多久
@export var pain_duration: float = 0.3

## 受击击退力度 — 值越大推得越远
@export var knockback_force: float = 3.0

## 死亡后尸体停留时间（秒）— 到期自动 queue_free
@export var death_duration: float = 2.0
